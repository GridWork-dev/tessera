---
// Emits one or more schema.org JSON-LD objects as a <script type="application/ld+json">.
// JSON-LD is the structured-data format Google recommends; it powers rich results
// (app cards, sitelinks, knowledge-panel signals). `set:html` is correct here —
// JSON.stringify output must NOT be HTML-escaped or parsers reject it.
interface Props {
  schema: Record<string, unknown> | Record<string, unknown>[];
}
const { schema } = Astro.props;
const json = JSON.stringify(schema);
---

<script type="application/ld+json" set:html={json} is:inline />

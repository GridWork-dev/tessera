---
// Hero demo video frame. When `src` is provided, renders a real autoplaying,
// muted, looping <video> (the Remotion-rendered hero loop) inside the framed
// stage; otherwise falls back to the static placeholder. Autoplay is gated on
// prefers-reduced-motion (poster shown, no motion) by the inline script below.
import Icon from "./Icon.astro";

interface Props {
  src?: string;
  webm?: string;
  poster?: string;
  caption?: string;
  class?: string;
}

const { src, webm, poster, caption = "Product demo · coming soon", class: cls } = Astro.props;
---

<figure class:list={["video", { "video--filled": !!src }, cls]}>
  <div class="video__stage">
    {
      src ? (
        <video
          class="video__player"
          muted
          loop
          playsinline
          preload="auto"
          poster={poster}
          data-hero-video
        >
          {webm && <source src={webm} type="video/webm" />}
          <source src={src} type="video/mp4" />
        </video>
      ) : (
        <>
          <div class="video__grid" aria-hidden="true"></div>
          <button class="video__play" type="button" aria-label="Play demo (placeholder)">
            <Icon name="play" size={28} />
          </button>
        </>
      )
    }
  </div>
  {caption && <figcaption class="video__caption muted">{caption}</figcaption>}
</figure>

{
  src && (
    <script>
      // Respect reduced-motion: only autoplay the looping hero when motion is OK.
      for (const v of document.querySelectorAll("video[data-hero-video]")) {
        if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          (v as HTMLVideoElement).play?.().catch(() => {});
        }
      }
    </script>
  )
}

<style>
  .video {
    margin: 0;
    width: 100%;
  }

  .video__stage {
    position: relative;
    aspect-ratio: 16 / 10;
    border-radius: var(--r-panel);
    border: 1px solid var(--line);
    background:
      radial-gradient(120% 120% at 70% 10%, var(--panel2), var(--sunken));
    box-shadow: var(--shadow-pop);
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  .video--filled .video__stage {
    aspect-ratio: 16 / 9;
  }

  .video__player {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .video__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--hair) 1px, transparent 1px),
      linear-gradient(90deg, var(--hair) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.4;
    mask-image: radial-gradient(120% 90% at 50% 40%, #000 30%, transparent 80%);
  }

  .video__play {
    position: relative;
    width: 72px;
    height: 72px;
    border-radius: var(--r-pill);
    background: var(--accent);
    color: var(--on-accent);
    border: none;
    display: grid;
    place-items: center;
    cursor: pointer;
    box-shadow: var(--shadow-pop);
    transition: transform 160ms ease-out;
  }

  .video__play:hover {
    transform: scale(1.04);
  }

  .video__caption {
    margin-top: var(--s3);
    font-size: 0.85rem;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .video__play {
      transition: none;
    }
  }
</style>

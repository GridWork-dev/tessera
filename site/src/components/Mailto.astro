---
// Lightly obfuscated mailto — splits user/domain so naive scrapers miss it,
// reassembled at click time. No trackers, no JS framework needed.
import Icon from "./Icon.astro";

interface Props {
  email: string; // full address, e.g. "admin@gettessera.xyz"
  label?: string;
}

const { email, label } = Astro.props;
const [user, domain] = email.split("@");
// Server-rendered fallback so the link works without JS. The inline script
// below still rewrites it (and reveals the text), but the href is real on load.
const mailtoHref = `mailto:${user}@${domain}`;
---

<a
  class="mailto"
  href={mailtoHref}
  data-user={user}
  data-domain={domain}
  rel="nofollow"
>
  <Icon name="mail" size={16} />
  <span>{label ?? `${user} [at] ${domain}`}</span>
</a>

<script>
  document.querySelectorAll<HTMLAnchorElement>("a.mailto").forEach((a) => {
    const user = a.dataset.user;
    const domain = a.dataset.domain;
    if (!user || !domain) return;
    const addr = `${user}@${domain}`;
    a.href = `mailto:${addr}`;
    const span = a.querySelector("span");
    if (span && span.textContent?.includes("[at]")) span.textContent = addr;
  });
</script>

<style>
  .mailto {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    color: var(--accent);
    font-weight: 500;
    word-break: break-all;
  }

  .mailto:hover {
    color: var(--accent);
    text-decoration: underline;
  }
</style>

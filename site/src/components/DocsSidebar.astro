---
import { getCollection } from "astro:content";
import { GITHUB_URL } from "../config";
import Icon from "./Icon.astro";

interface Props {
  activeSlug?: string; // the current doc id, undefined on the index landing
}

const { activeSlug } = Astro.props;

// Load every doc, sort by `order` (global), then bucket by `group` preserving
// first-seen order so groups appear in ascending-order sequence.
const docs = await getCollection("docs");
const sorted = docs.sort((a, b) => a.data.order - b.data.order);

const groups: { name: string; items: typeof sorted }[] = [];
for (const entry of sorted) {
  const group = entry.data.group;
  let bucket = groups.find((g) => g.name === group);
  if (!bucket) {
    bucket = { name: group, items: [] };
    groups.push(bucket);
  }
  bucket.items.push(entry);
}
---

<nav class="docnav" aria-label="Documentation">
  {
    groups.map((g) => (
      <div class="docnav__group">
        <p class="docnav__title">{g.name}</p>
        <ul class="docnav__list">
          {g.items.map((item) => {
            const isActive = item.id === activeSlug;
            return (
              <li>
                <a
                  href={`/docs/${item.id}`}
                  class:list={["docnav__link", { "is-active": isActive }]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
  <a
    class="docnav__repo"
    href={GITHUB_URL}
    target="_blank"
    rel="noopener noreferrer"
  >
    <Icon name="github" size={15} /> Source on GitHub
  </a>
</nav>

<style>
  .docnav {
    display: flex;
    flex-direction: column;
    gap: var(--s5);
  }
  .docnav__group {
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }
  .docnav__title {
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--fore3);
    font-weight: 600;
    margin-bottom: var(--s1);
  }
  .docnav__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    border-left: 1px solid var(--line);
  }
  .docnav__link {
    display: block;
    padding: 5px var(--s3);
    margin-left: -1px;
    border-left: 2px solid transparent;
    color: var(--fore2);
    font-size: 0.92rem;
    line-height: 1.35;
  }
  .docnav__link:hover {
    color: var(--fore);
  }
  .docnav__link.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
    font-weight: 600;
  }
  .docnav__repo {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    margin-top: var(--s2);
    color: var(--fore3);
    font-size: 0.86rem;
  }
  .docnav__repo:hover {
    color: var(--accent);
  }
</style>

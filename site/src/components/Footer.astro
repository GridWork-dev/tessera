---
import {
  SITE_NAME,
  GITHUB_URL,
  RELEASES_URL,
  DISCUSSIONS_URL,
} from "../config";

const year = new Date().getFullYear();

const cols = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "/features" },
      { label: "Pricing", href: "/pricing" },
      { label: "Download", href: "/download" },
      { label: "Changelog", href: "/changelog" },
    ],
  },
  {
    title: "Open source",
    links: [
      { label: "GitHub", href: GITHUB_URL, external: true },
      { label: "Releases", href: RELEASES_URL, external: true },
      { label: "Self-host", href: "/docs/configuration#self-hosting-the-backend" },
      { label: "License (AGPLv3)", href: "/license" },
    ],
  },
  {
    title: "Resources",
    links: [
      { label: "Docs", href: "/docs" },
      { label: "Discussions", href: DISCUSSIONS_URL, external: true },
      { label: "About", href: "/about" },
      { label: "Contact", href: "/contact" },
    ],
  },
  {
    title: "Legal",
    links: [
      { label: "Privacy", href: "/privacy" },
      { label: "Acceptable use", href: "/aup" },
      { label: "License & EULA", href: "/license" },
      { label: "CLA", href: `${GITHUB_URL}/blob/main/CLA.md`, external: true },
    ],
  },
];
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__wordmark" aria-label={`${SITE_NAME} home`}>
        <svg class="footer__mark" width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="2" y="2" width="9.2" height="9.2" rx="2.2" fill="#475160" />
          <rect x="12.8" y="2" width="9.2" height="9.2" rx="2.2" fill="#2fd6a0" />
          <rect x="2" y="12.8" width="9.2" height="9.2" rx="2.2" fill="#475160" />
          <rect x="12.8" y="12.8" width="9.2" height="9.2" rx="2.2" fill="#475160" />
        </svg>
        <span>{SITE_NAME}</span>
      </a>
      <p class="muted footer__tag">
        Private, local AI for your image & video library. No cloud, ever.
      </p>
    </div>

    <div class="footer__cols">
      {
        cols.map((col) => (
          <div class="footer__col">
            <p class="footer__title">{col.title}</p>
            <ul class="footer__list">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    target={l.external ? "_blank" : undefined}
                    rel={l.external ? "noopener noreferrer" : undefined}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="container footer__base">
    <span class="muted">© {year} {SITE_NAME}. Open core under AGPLv3.</span>
    <span class="muted">We host no user media — nothing to take down.</span>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hair);
    background: var(--panel);
    padding-top: var(--s8);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.4fr 3fr;
    gap: var(--s7);
  }

  .footer__wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    font-weight: 700;
    color: var(--fore);
  }

  .footer__tag {
    margin-top: var(--s3);
    max-width: 28ch;
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .footer__cols {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--s5);
  }

  .footer__title {
    font-size: 12px;
    color: var(--fore3);
    margin-bottom: var(--s3);
    font-weight: 600;
  }

  .footer__list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }

  .footer__list a {
    color: var(--fore2);
    font-size: 0.92rem;
  }

  .footer__list a:hover {
    color: var(--accent);
  }

  .footer__base {
    display: flex;
    justify-content: space-between;
    gap: var(--s4);
    flex-wrap: wrap;
    padding-block: var(--s5);
    margin-top: var(--s7);
    border-top: 1px solid var(--hair);
    font-size: 0.85rem;
  }

  @media (max-width: 860px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--s6);
    }
    .footer__cols {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

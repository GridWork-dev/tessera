---
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<header class="ph">
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1>{title}</h1>
  {lead && <p class="lead ph__lead">{lead}</p>}
</header>

<style>
  .ph {
    max-width: 56ch;
  }

  .ph__lead {
    margin-top: var(--s4);
  }
</style>

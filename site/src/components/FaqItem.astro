---
import Icon from "./Icon.astro";

interface Props {
  q: string;
  open?: boolean;
}

const { q, open } = Astro.props;
---

<details class="faq" open={open}>
  <summary class="faq__q">
    <span>{q}</span>
    <Icon name="chevron-down" size={18} class="faq__chevron" />
  </summary>
  <div class="faq__a muted"><slot /></div>
</details>

<style>
  .faq {
    border-bottom: 1px solid var(--hair);
  }

  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s4);
    cursor: pointer;
    list-style: none;
    padding-block: var(--s4);
    font-weight: 600;
    color: var(--fore);
    font-size: 1.02rem;
  }

  .faq__q::-webkit-details-marker {
    display: none;
  }

  /* :global — the chevron is rendered by the <Icon> child component, so its SVG
     never receives this component's scope hash. Target the class globally. */
  .faq :global(.faq__chevron) {
    flex: none;
    color: var(--fore3);
    transition: transform 160ms ease-out;
  }

  .faq[open] :global(.faq__chevron) {
    transform: rotate(180deg);
  }

  .faq__a {
    padding-bottom: var(--s4);
    max-width: 70ch;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq :global(.faq__chevron) {
      transition: none;
    }
  }
</style>

---
import { SITE_NAME, NAV, GITHUB_URL, RELEASES_URL } from "../config";
import Icon from "./Icon.astro";
import Button from "./Button.astro";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label={`${SITE_NAME} home`}>
      <svg class="nav__mark" width="22" height="22" viewBox="0 0 24 24" aria-hidden="true">
        <rect x="2" y="2" width="9.2" height="9.2" rx="2.2" fill="#475160" />
        <rect x="12.8" y="2" width="9.2" height="9.2" rx="2.2" fill="#2fd6a0" />
        <rect x="2" y="12.8" width="9.2" height="9.2" rx="2.2" fill="#475160" />
        <rect x="12.8" y="12.8" width="9.2" height="9.2" rx="2.2" fill="#475160" />
      </svg>
      <span>{SITE_NAME}</span>
    </a>

    <nav class="nav__links" aria-label="Primary">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            class:list={["nav__link", { "is-active": isActive(item.href) }]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="nav__actions">
      <a class="nav__github" href={GITHUB_URL} target="_blank" rel="noopener noreferrer">
        <Icon name="github" size={18} />
        <span>GitHub</span>
      </a>
      <Button href={RELEASES_URL} icon="download" external>Download</Button>
    </div>

    <button
      class="nav__toggle"
      type="button"
      aria-label="Open menu"
      aria-controls="nav-mobile"
      aria-expanded="false"
    >
      <span class="nav__toggle-icon nav__toggle-open"><Icon name="menu" size={22} /></span>
      <span class="nav__toggle-icon nav__toggle-close"><Icon name="x" size={22} /></span>
    </button>
  </div>

  <nav id="nav-mobile" class="nav__mobile" aria-label="Primary">
    {
      NAV.map((item) => (
        <a
          href={item.href}
          class:list={["nav__mobile-link", { "is-active": isActive(item.href) }]}
          aria-current={isActive(item.href) ? "page" : undefined}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--void);
    border-bottom: 1px solid var(--hair);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: var(--s5);
    height: 64px;
  }

  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    color: var(--fore);
  }

  .nav__brand:hover {
    color: var(--fore);
  }

  .nav__links {
    display: flex;
    gap: var(--s5);
    margin-inline-start: var(--s4);
  }

  .nav__link {
    color: var(--fore2);
    font-size: 0.95rem;
    font-weight: 500;
    padding-block: var(--s2);
  }

  .nav__link:hover {
    color: var(--fore);
  }

  .nav__link.is-active {
    color: var(--fore);
  }

  .nav__actions {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-inline-start: auto;
  }

  .nav__github {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    color: var(--fore2);
    font-weight: 500;
    font-size: 0.95rem;
  }

  .nav__github:hover {
    color: var(--fore);
  }

  /* Mobile disclosure — hidden on desktop, shown ≤860px */
  .nav__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--r-button);
    border: 1px solid var(--line);
    background: transparent;
    color: var(--fore2);
    cursor: pointer;
  }

  .nav__toggle:hover {
    color: var(--fore);
    border-color: var(--line2);
  }

  .nav__toggle-icon {
    display: inline-flex;
  }

  .nav__toggle-close {
    display: none;
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-open {
    display: none;
  }

  .nav__toggle[aria-expanded="true"] .nav__toggle-close {
    display: inline-flex;
  }

  .nav__mobile {
    display: none;
  }

  @media (max-width: 860px) {
    .nav__links {
      display: none;
    }

    .nav__toggle {
      display: inline-flex;
    }

    .nav__mobile {
      display: flex;
      flex-direction: column;
      gap: var(--s1);
      position: absolute;
      inset-inline: 0;
      top: 100%;
      padding: var(--s3) var(--s5) var(--s4);
      background: var(--panel);
      border-bottom: 1px solid var(--line);
      box-shadow: var(--shadow-pop);
      /* closed state — kept out of the tab order via visibility */
      opacity: 0;
      visibility: hidden;
      transform: translateY(-8px);
      transition:
        opacity 160ms ease-out,
        transform 160ms ease-out,
        visibility 0s linear 160ms;
    }

    .nav__mobile.is-open {
      opacity: 1;
      visibility: visible;
      transform: none;
      transition:
        opacity 160ms ease-out,
        transform 160ms ease-out;
    }

    .nav__mobile-link {
      color: var(--fore2);
      font-size: 1rem;
      font-weight: 500;
      padding-block: var(--s3);
      border-bottom: 1px solid var(--hair);
    }

    .nav__mobile-link:last-child {
      border-bottom: none;
    }

    .nav__mobile-link:hover,
    .nav__mobile-link.is-active {
      color: var(--fore);
    }
  }

  @media (max-width: 560px) {
    .nav__github span {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav__mobile,
    .nav__mobile.is-open {
      transition: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav__toggle");
  const menu = document.getElementById("nav-mobile");

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      menu.classList.toggle("is-open", open);
    };

    toggle.addEventListener("click", () => {
      setOpen(toggle.getAttribute("aria-expanded") !== "true");
    });

    // Close on link tap so navigation never leaves the menu open.
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) setOpen(false);
    });

    // Escape closes and returns focus to the trigger.
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
        setOpen(false);
        toggle.focus();
      }
    });
  }
</script>

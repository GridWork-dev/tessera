---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import PageHeader from "../components/PageHeader.astro";
import Icon from "../components/Icon.astro";
import "../styles/content.css";
import {
  DISCUSSIONS_URL,
  SECURITY_URL,
  EMAIL_CONTACT,
} from "../config";

// TODO: replace with the real Cloudflare Turnstile *site* key.
const TURNSTILE_SITE_KEY = "0x4AAAAAADrHpkeFQoR8AKbo";
---

<Base title="Contact" description="Send us a message, get community help via GitHub Discussions, or report a security issue. No live chat, no trackers.">
  <Section>
    <PageHeader
      eyebrow="Contact"
      title="Get in touch."
      lead="Send a message below and we'll reply, usually within 2–3 business days. No live chat, no trackers."
    />

    <div class="contact-layout">
      <!-- Primary: real contact form posting to the Pages Function. -->
      <form
        id="contact-form"
        class="card form"
        method="POST"
        action="/api/contact"
      >
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required maxlength="100" autocomplete="name" />
        </div>

        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required maxlength="254" autocomplete="email" />
        </div>

        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" required maxlength="5000" rows={6}></textarea>
        </div>

        <!-- Cloudflare Turnstile. Renders its own hidden input named
             "cf-turnstile-response". Without JS it simply won't render and the
             no-JS fallback note below points the user at email. -->
        <div class="cf-turnstile" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark"></div>

        <noscript>
          <p class="muted nojs">
            This form needs JavaScript for spam protection. With it disabled,
            email us directly at <strong>{EMAIL_CONTACT}</strong>.
          </p>
        </noscript>

        <button type="submit" class="btn btn--primary">
          <Icon name="send" size={18} /> <span>Send message</span>
        </button>

        <p id="form-status" class="form-status" role="status" aria-live="polite"></p>
      </form>

      <!-- Secondary channels. -->
      <aside class="channels">
        <div class="card cc">
          <div class="cc__icon"><Icon name="messages-square" size={20} /></div>
          <h3>Community help</h3>
          <p class="muted">
            Questions, ideas, and troubleshooting happen in the open on GitHub
            Discussions — searchable for the next person.
          </p>
          <a class="cc__link" href={DISCUSSIONS_URL} target="_blank" rel="noopener noreferrer">
            <Icon name="github" size={16} /> Open GitHub Discussions
          </a>
        </div>

        <div class="card cc">
          <div class="cc__icon"><Icon name="shield-alert" size={20} /></div>
          <h3>Security disclosure</h3>
          <p class="muted">
            Found a vulnerability? Please use GitHub Private Vulnerability
            Reporting. We'll acknowledge and work with you on a fix.
          </p>
          <a class="cc__link" href={SECURITY_URL} target="_blank" rel="noopener noreferrer">
            <Icon name="github" size={16} /> Private Vulnerability Reporting
          </a>
        </div>

        <div class="note">
          <Icon name="lock" size={18} />
          <p>
            We host no user media — your library never reaches us, so there's
            nothing for us to access, leak, or take down.
          </p>
        </div>
      </aside>
    </div>
  </Section>
</Base>

<!-- Cloudflare Turnstile widget script. Loads the data-sitekey widget above. -->
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer is:inline></script>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");
  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submit = form.querySelector<HTMLButtonElement>("button[type=submit]");
      status.className = "form-status";
      status.textContent = "";
      if (submit) submit.disabled = true;

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          body: new FormData(form),
        });
        const data = (await res.json().catch(() => ({}))) as { ok?: boolean };
        if (res.ok && data.ok) {
          form.reset();
          // Reset the Turnstile widget so a second send needs a fresh token.
          (window as unknown as { turnstile?: { reset: () => void } }).turnstile?.reset();
          status.className = "form-status form-status--ok";
          status.textContent = "Thanks — your message is on its way. Check your inbox for a confirmation.";
        } else if (res.status === 403) {
          status.className = "form-status form-status--err";
          status.textContent = "Spam check failed. Please complete the challenge and try again.";
        } else if (res.status === 400) {
          status.className = "form-status form-status--err";
          status.textContent = "Please fill in your name, a valid email, and a message.";
        } else {
          status.className = "form-status form-status--err";
          status.textContent = "Something went wrong sending your message. Please try again or email us directly.";
        }
      } catch {
        status.className = "form-status form-status--err";
        status.textContent = "Network error. Please try again or email us directly.";
      } finally {
        if (submit) submit.disabled = false;
      }
    });
  }
</script>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--s5);
    margin-top: var(--s6);
    align-items: start;
  }
  @media (max-width: 820px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--s4);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }
  .field label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--fore2);
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 10px var(--s3);
    background: var(--panel2);
    border: 1px solid var(--line);
    border-radius: var(--r-button);
    color: var(--fore);
    font: inherit;
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .field textarea {
    resize: vertical;
    min-height: 120px;
  }
  .field input:focus-visible,
  .field textarea:focus-visible {
    outline: none;
    border-color: var(--accent2);
    box-shadow: var(--focus);
  }

  .form .btn {
    align-self: flex-start;
  }

  .nojs {
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .form-status {
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    min-height: 1.2em;
  }
  .form-status--ok {
    color: var(--accent);
  }
  .form-status--err {
    color: var(--nsfw);
  }

  .channels {
    display: flex;
    flex-direction: column;
    gap: var(--s4);
  }
  .cc {
    display: flex;
    flex-direction: column;
    gap: var(--s3);
  }
  .cc__icon {
    width: 40px;
    height: 40px;
    border-radius: var(--r-tile);
    display: grid;
    place-items: center;
    background: var(--accent-weak);
    color: var(--accent);
    border: 1px solid var(--accent2);
  }
  .cc p {
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .cc__link {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    color: var(--accent);
    font-weight: 500;
    font-size: 0.95rem;
  }
  .cc__link:hover {
    text-decoration: underline;
  }

  .note {
    display: flex;
    align-items: flex-start;
    gap: var(--s3);
    padding: var(--s4);
    background: var(--accent-weak);
    border: 1px solid var(--accent2);
    border-radius: var(--r-tile);
    color: var(--fore2);
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .note :global(svg) {
    color: var(--accent);
    flex: none;
    margin-top: 2px;
  }

  /* Reuse the Button component's styling for the native submit button. */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    border-radius: var(--r-button);
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1;
    letter-spacing: 0.01em;
    border: 1px solid transparent;
    cursor: pointer;
    padding: 10px var(--s4);
    transition:
      background-color 160ms ease-out,
      border-color 160ms ease-out,
      color 160ms ease-out;
  }
  .btn--primary {
    background: var(--accent);
    color: var(--on-accent);
    border-color: var(--accent);
  }
  .btn--primary:hover {
    background: color-mix(in srgb, var(--accent) 88%, white);
    border-color: color-mix(in srgb, var(--accent) 88%, white);
  }
  .btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  @media (prefers-reduced-motion: reduce) {
    .btn {
      transition: none;
    }
  }
</style>

---
import { getCollection } from "astro:content";
import DocsLayout from "../layouts/DocsLayout.astro";
import Icon from "../components/Icon.astro";
import { SITE_NAME } from "../config";

// Build the landing from the same collection the sidebar reads, so the index
// can never drift from the actual set of docs. Group + order mirror the rail.
const docs = await getCollection("docs");
const sorted = docs.sort((a, b) => a.data.order - b.data.order);

const groups: { name: string; items: typeof sorted }[] = [];
for (const entry of sorted) {
  let bucket = groups.find((g) => g.name === entry.data.group);
  if (!bucket) {
    bucket = { name: entry.data.group, items: [] };
    groups.push(bucket);
  }
  bucket.items.push(entry);
}

const start = sorted[0];
---

<DocsLayout
  title="Docs"
  description={`Documentation for ${SITE_NAME} — install, first-run setup, tagging and semantic search, faces, videos, configuration, privacy, and licensing.`}
>
  <header class="docindex__head">
    <p class="eyebrow">Documentation</p>
    <h1>{SITE_NAME} documentation</h1>
    <p class="lead docindex__lead">
      Everything needed to install, configure, and run {SITE_NAME} — a private,
      local-first AI digital-asset manager. Pick a section, or start at the
      beginning.
    </p>
    {
      start && (
        <a class="docindex__start" href={`/docs/${start.id}`}>
          Start with {start.data.title}
          <Icon name="arrow-right" size={16} />
        </a>
      )
    }
  </header>

  <div class="docindex__groups">
    {
      groups.map((g) => (
        <section class="docindex__group">
          <h2 class="docindex__group-title">{g.name}</h2>
          <ul class="docindex__cards">
            {g.items.map((item) => (
              <li>
                <a class="doccard" href={`/docs/${item.id}`}>
                  <span class="doccard__title">
                    {item.data.title}
                    <Icon name="arrow-up-right" size={16} />
                  </span>
                  <span class="doccard__desc">{item.data.description}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </div>
</DocsLayout>

<style>
  .docindex__head {
    max-width: 60ch;
    padding-bottom: var(--s6);
    margin-bottom: var(--s6);
    border-bottom: 1px solid var(--hair);
  }
  .docindex__head h1 {
    margin-top: var(--s2);
    font-size: clamp(1.8rem, 1.4rem + 1.6vw, 2.5rem);
  }
  .docindex__lead {
    margin-top: var(--s4);
  }
  .docindex__start {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    margin-top: var(--s5);
    color: var(--accent);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .docindex__start:hover {
    text-decoration: underline;
  }

  .docindex__groups {
    display: flex;
    flex-direction: column;
    gap: var(--s7);
  }
  .docindex__group-title {
    font-size: 1.2rem;
    margin-bottom: var(--s4);
  }
  .docindex__cards {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s3);
  }

  .doccard {
    display: flex;
    flex-direction: column;
    gap: var(--s2);
    height: 100%;
    padding: var(--s4);
    background: var(--panel2);
    border: 1px solid var(--hair);
    border-radius: var(--r-tile);
    transition:
      border-color 160ms ease-out,
      background-color 160ms ease-out;
  }
  .doccard:hover {
    border-color: var(--line2);
    background: var(--surface);
    color: var(--fore);
  }
  .doccard__title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s2);
    font-weight: 600;
    font-size: 1rem;
    color: var(--fore);
  }
  .doccard__title :global(svg) {
    color: var(--fore3);
    flex: none;
  }
  .doccard:hover .doccard__title :global(svg) {
    color: var(--accent);
  }
  .doccard__desc {
    color: var(--fore2);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .docindex__cards {
      grid-template-columns: 1fr;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .doccard {
      transition: none;
    }
  }
</style>

---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import PageHeader from "../components/PageHeader.astro";
import PlanCard from "../components/PlanCard.astro";
import FaqItem from "../components/FaqItem.astro";
import Icon from "../components/Icon.astro";
import "../styles/content.css";
import { RELEASES_URL, POLAR_CHECKOUT_URL, PRICE_PRO, PRICE_FREE } from "../config";

type Cell = boolean | string;
const rows: { label: string; free: Cell; pro: Cell }[] = [
  { label: "Semantic search & visual similarity", free: true, pro: true },
  { label: "Auto-tagging & captions", free: true, pro: true },
  { label: "Faces & people", free: true, pro: true },
  { label: "Places & events", free: true, pro: true },
  { label: "Video scenes & transcripts", free: true, pro: true },
  { label: "100% local · no telemetry", free: true, pro: true },
  { label: "Self-host with Docker", free: true, pro: true },
  { label: "Advanced personalization", free: false, pro: true },
  { label: "Bring-your-own remote compute key", free: false, pro: true },
  { label: "Priority email support", free: false, pro: "2–3 biz days" },
  { label: "License", free: "AGPLv3", pro: "Pro EULA" },
];

const licensingFaqs = [
  { q: "Is Pro a subscription?", a: "No. Pro is a single one-time purchase. There is no recurring charge, ever." },
  { q: "What does \"perpetual for this major\" mean?", a: "Your purchase unlocks Pro for the current major version, forever. You keep using it offline with no expiry. A future major version is a separate, optional one-time purchase." },
  { q: "Do I have to upgrade?", a: "Never. We use a soft gate — a gentle prompt — when a newer major exists, never a hard lockout. Your installed version keeps working." },
  { q: "Does Pro phone home to check my license?", a: "No. License validation is offline. Pro never calls a server to verify you, so it works on an air-gapped machine." },
  { q: "What happens to my data if I stop paying?", a: "Nothing — there's nothing to stop. You bought it once. Your library and your app stay exactly where they are, on your machine." },
];
---

<Base title="Pricing" description={`The Free edition is open source — the full local pipeline at no cost. Pro is a one-time ${PRICE_PRO} purchase — perpetual for that major, no subscription, no phone-home.`}>
  <Section>
    <PageHeader
      eyebrow="Pricing"
      title="Free forever. Pro once — no subscription."
      lead="The full local pipeline is open source. Pro adds power features and support for a single one-time price."
    />
    <div class="grid grid--2 plans">
      <PlanCard
        name="Free"
        price={PRICE_FREE}
        cadence="open source"
        blurb="The complete local pipeline, AGPLv3. Run it, audit it, self-host it."
        features={["Semantic search & auto-tagging", "Faces, places & video scenes", "100% local · no telemetry", "Self-host with Docker"]}
        ctaLabel="Download"
        ctaHref={RELEASES_URL}
        ctaVariant="ghost"
        external
      />
      <PlanCard
        name="Pro"
        price={PRICE_PRO}
        cadence="one-time · perpetual for this major"
        blurb="Power features and priority support. Pay once, own it — no subscription, no phone-home."
        features={["Everything in Free", "Advanced personalization", "Bring-your-own remote compute key", "Priority email support"]}
        ctaLabel="Buy Pro"
        ctaHref={POLAR_CHECKOUT_URL}
        ctaVariant="primary"
        featured
      />
    </div>
  </Section>

  <Section tone="panel">
    <header class="block-head">
      <p class="eyebrow">Compare</p>
      <h2>What's in each edition.</h2>
    </header>
    <div class="table-wrap">
      <table class="ctable">
        <thead>
          <tr>
            <th scope="col">Feature</th>
            <th scope="col">Free</th>
            <th scope="col" class="ctable__pro">Pro</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((r) => (
            <tr>
              <th scope="row">{r.label}</th>
              <td>
                {typeof r.free === "boolean"
                  ? r.free
                    ? <Icon name="check" size={18} label="Included" />
                    : <Icon name="minus" size={18} label="Not included" class="ctable__absent" />
                  : <span class="muted">{r.free}</span>}
              </td>
              <td class="ctable__pro">
                {typeof r.pro === "boolean"
                  ? r.pro
                    ? <Icon name="check" size={18} label="Included" />
                    : <Icon name="minus" size={18} label="Not included" class="ctable__absent" />
                  : <span>{r.pro}</span>}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </Section>

  <Section>
    <header class="block-head">
      <p class="eyebrow">Licensing</p>
      <h2>How the Pro license works.</h2>
    </header>
    <div class="faq-list">
      {licensingFaqs.map((f, i) => <FaqItem q={f.q} open={i === 0}>{f.a}</FaqItem>)}
    </div>
  </Section>
</Base>

<style>
  .plans {
    margin-top: var(--s6);
  }

  .table-wrap {
    overflow-x: auto;
    border: 1px solid var(--hair);
    border-radius: var(--r-panel);
    background: var(--panel2);
  }
  .ctable {
    width: 100%;
    border-collapse: collapse;
    min-width: 520px;
  }
  .ctable th,
  .ctable td {
    text-align: left;
    padding: var(--s3) var(--s4);
    border-bottom: 1px solid var(--hair);
    font-size: 0.95rem;
  }
  .ctable thead th {
    color: var(--fore3);
    font-size: 12px;
    font-weight: 600;
  }
  .ctable tbody th {
    font-weight: 500;
    color: var(--fore2);
  }
  .ctable td {
    width: 160px;
    color: var(--fore2);
  }
  .ctable td :global(svg) {
    color: var(--accent);
  }
  /* "Not included" minus is absence, not a feature — mute it so sighted users
     read present (accent) vs absent (muted) at a glance, not two accents. */
  .ctable td :global(svg.ctable__absent) {
    color: var(--fore4);
  }
  .ctable .ctable__pro {
    background: color-mix(in srgb, var(--accent-weak) 60%, transparent);
  }
  .ctable tbody tr:last-child th,
  .ctable tbody tr:last-child td {
    border-bottom: none;
  }

  .faq-list {
    max-width: 760px;
  }
</style>

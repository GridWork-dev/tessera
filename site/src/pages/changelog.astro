---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import PageHeader from "../components/PageHeader.astro";
import Icon from "../components/Icon.astro";
import "../styles/content.css";
import { SITE_NAME, RELEASES_URL } from "../config";

// Static seed — keep in sync with CHANGELOG.md / GitHub Releases for v1.
const releases = [
  {
    version: "0.4.0",
    date: "2026-06-24",
    tag: "Latest",
    notes: [
      "Video pillar: scene detection, keyframe posters, and local transcripts.",
      "Personalization learns your keep / reject signal to improve ranking.",
      "Places & events clustering from EXIF time and location.",
    ],
  },
  {
    version: "0.3.0",
    date: "2026-05",
    notes: [
      "Faces & people: local face clustering, name once and find everywhere.",
      "Semantic search upgraded with visual similarity (\"more like this\").",
    ],
  },
  {
    version: "0.2.0",
    date: "2026-04",
    notes: [
      "Auto-tagging and written captions for every asset, fully offline.",
      "Self-host Docker image published.",
    ],
  },
  {
    version: "0.1.0",
    date: "2026-03",
    notes: ["First public build: local indexing and natural-language search."],
  },
];
---

<Base title="Changelog" description={`What's new in ${SITE_NAME} — release notes for each version.`}>
  <Section>
    <PageHeader
      eyebrow="Changelog"
      title="What's new."
      lead="Notable changes per release. Full release notes and assets live on GitHub."
    />

    <ol class="log">
      {releases.map((r) => (
        <li class="rel">
          <div class="rel__meta">
            <span class="rel__ver">v{r.version}</span>
            {r.tag && <span class="rel__tag">{r.tag}</span>}
            <time class="rel__date muted">{r.date}</time>
          </div>
          <ul class="rel__notes">
            {r.notes.map((n) => (
              <li><Icon name="dot" size={18} /><span>{n}</span></li>
            ))}
          </ul>
        </li>
      ))}
    </ol>

    <p class="muted log__note">
      <a href={RELEASES_URL} target="_blank" rel="noopener noreferrer">
        Full release notes & downloads on GitHub →
      </a>
    </p>
  </Section>
</Base>

<style>
  .log {
    list-style: none;
    padding: 0;
    margin-top: var(--s6);
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--s6);
  }
  .rel {
    padding-bottom: var(--s6);
    border-bottom: 1px solid var(--hair);
  }
  .rel:last-child {
    border-bottom: none;
  }
  .rel__meta {
    display: flex;
    align-items: center;
    gap: var(--s3);
    margin-bottom: var(--s3);
  }
  .rel__ver {
    font-weight: 700;
    font-size: 1.1rem;
  }
  .rel__tag {
    font-size: 11px;
    font-weight: 600;
    color: var(--fore3);
    background: var(--accent-weak);
    border: 1px solid var(--accent2);
    border-radius: var(--r-pill);
    padding: 3px 9px;
  }
  .rel__date {
    font-size: 0.85rem;
    margin-left: auto;
  }
  .rel__notes {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }
  .rel__notes li {
    display: flex;
    align-items: flex-start;
    gap: var(--s1);
    color: var(--fore2);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .rel__notes :global(svg) {
    color: var(--accent);
    flex: none;
    margin-top: 1px;
  }
  .log__note {
    margin-top: var(--s6);
  }
</style>

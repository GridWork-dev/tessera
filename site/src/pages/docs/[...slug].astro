---
import { getCollection, render } from "astro:content";
import DocsLayout from "../../layouts/DocsLayout.astro";
import Icon from "../../components/Icon.astro";
import { SITE_NAME } from "../../config";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  const sorted = docs.sort((a, b) => a.data.order - b.data.order);
  return sorted.map((entry, i) => ({
    // entry.id is the slug (e.g. "install"); maps to /docs/install.
    params: { slug: entry.id },
    props: {
      entry,
      prev: i > 0 ? sorted[i - 1] : null,
      next: i < sorted.length - 1 ? sorted[i + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
---

<DocsLayout
  title={entry.data.title}
  description={entry.data.description}
  activeSlug={entry.id}
>
  <article class="doc">
    <header class="doc__head">
      <p class="eyebrow">{entry.data.group}</p>
      <h1>{entry.data.title}</h1>
      <p class="lead doc__lead">{entry.data.description}</p>
    </header>

    <div class="doc__body prose">
      <Content />
    </div>

    <nav class="doc__pager" aria-label="Documentation pages">
      {
        prev ? (
          <a class="doc__pager-link doc__pager-link--prev" href={`/docs/${prev.id}`}>
            <Icon name="arrow-left" size={16} />
            <span class="doc__pager-meta">
              <span class="doc__pager-dir">Previous</span>
              <span class="doc__pager-title">{prev.data.title}</span>
            </span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next && (
          <a class="doc__pager-link doc__pager-link--next" href={`/docs/${next.id}`}>
            <span class="doc__pager-meta">
              <span class="doc__pager-dir">Next</span>
              <span class="doc__pager-title">{next.data.title}</span>
            </span>
            <Icon name="arrow-right" size={16} />
          </a>
        )
      }
    </nav>
  </article>
</DocsLayout>

<style>
  .doc {
    max-width: 76ch;
  }
  .doc__head {
    padding-bottom: var(--s5);
    margin-bottom: var(--s6);
    border-bottom: 1px solid var(--hair);
  }
  .doc__head h1 {
    margin-top: var(--s2);
    font-size: clamp(1.8rem, 1.4rem + 1.4vw, 2.4rem);
  }
  .doc__lead {
    margin-top: var(--s4);
    max-width: 64ch;
  }

  /* Markdown body. Builds on .prose (content.css); these rules cover the
     elements .prose doesn't, and tune rhythm for long-form docs. */
  .doc__body :global(h2) {
    color: var(--fore);
    font-size: 1.35rem;
    margin-top: var(--s7);
    margin-bottom: var(--s3);
    padding-top: var(--s2);
  }
  .doc__body :global(h3) {
    color: var(--fore);
    font-size: 1.08rem;
    margin-top: var(--s5);
    margin-bottom: var(--s2);
  }
  .doc__body :global(p),
  .doc__body :global(ul),
  .doc__body :global(ol) {
    margin-bottom: var(--s4);
  }
  .doc__body :global(li) {
    margin-bottom: var(--s2);
  }
  .doc__body :global(li > p) {
    margin-bottom: var(--s2);
  }
  .doc__body :global(strong) {
    color: var(--fore);
    font-weight: 600;
  }
  .doc__body :global(pre) {
    background: var(--sunken);
    border: 1px solid var(--hair);
    border-radius: var(--r-tile);
    padding: var(--s4);
    overflow-x: auto;
    font-size: 0.85rem;
    line-height: 1.6;
    margin-bottom: var(--s4);
  }
  .doc__body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--fore2);
    font-size: inherit;
  }
  .doc__body :global(blockquote) {
    margin: 0 0 var(--s4);
    padding-left: var(--s4);
    border-left: 2px solid var(--line2);
    color: var(--fore3);
  }
  .doc__body :global(hr) {
    border: 0;
    border-top: 1px solid var(--line);
    margin-block: var(--s6);
  }

  .doc__pager {
    display: flex;
    justify-content: space-between;
    gap: var(--s4);
    margin-top: var(--s8);
    padding-top: var(--s5);
    border-top: 1px solid var(--hair);
  }
  .doc__pager-link {
    display: inline-flex;
    align-items: center;
    gap: var(--s3);
    padding: var(--s3) var(--s4);
    border: 1px solid var(--hair);
    border-radius: var(--r-tile);
    background: var(--panel2);
    max-width: 48%;
    transition:
      border-color 160ms ease-out,
      background-color 160ms ease-out;
  }
  .doc__pager-link:hover {
    border-color: var(--line2);
    background: var(--surface);
    color: var(--fore);
  }
  .doc__pager-link--next {
    margin-left: auto;
    text-align: right;
  }
  .doc__pager-link :global(svg) {
    color: var(--fore3);
    flex: none;
  }
  .doc__pager-link:hover :global(svg) {
    color: var(--accent);
  }
  .doc__pager-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .doc__pager-dir {
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--fore3);
    font-weight: 600;
  }
  .doc__pager-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fore);
  }

  @media (max-width: 560px) {
    .doc__pager-link {
      max-width: none;
    }
    .doc__pager-dir {
      display: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .doc__pager-link {
      transition: none;
    }
  }
</style>

---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import PageHeader from "../components/PageHeader.astro";
import Mailto from "../components/Mailto.astro";
import "../styles/content.css";
import { SITE_NAME, EMAIL_ABUSE } from "../config";
---

<Base title="Acceptable Use" description={`The ${SITE_NAME} acceptable use policy — one screen. We host no user media; you are responsible for your own library and for obeying the law.`}>
  <Section>
    <PageHeader
      eyebrow="Legal"
      title="Acceptable use"
      lead={`One screen. ${SITE_NAME} runs on your hardware with your content — these are the ground rules.`}
    />
    <div class="prose legal">
      <h2>Your library is yours</h2>
      <p>
        {SITE_NAME} processes whatever assets you point it at, on your own machine. We
        don't inspect, scan, or restrict the contents of your private library, and we host
        no copy of it. With that freedom comes responsibility: <strong>you</strong> are
        accountable for the content you store and for complying with the laws that apply
        to you.
      </p>

      <h2>You must not</h2>
      <ul>
        <li>Use {SITE_NAME} to store, produce, or distribute content that is illegal in your jurisdiction — including, without limitation, child sexual abuse material (CSAM).</li>
        <li>Use the software to violate the rights of others, including privacy and intellectual-property rights.</li>
        <li>Circumvent the Pro license terms, resell license keys, or misrepresent the software as your own.</li>
        <li>Use the project's name, logo, or releases to deceive others or imply official endorsement.</li>
      </ul>

      <h2>Security &amp; integrity</h2>
      <ul>
        <li>Don't attempt to compromise our website, release infrastructure, or other users.</li>
        <li>Report vulnerabilities responsibly via Private Vulnerability Reporting (see <a href="/contact">Contact</a>).</li>
      </ul>

      <h2>Reporting &amp; enforcement</h2>
      <p>
        We host no user media, so there is typically nothing for us to remove. Where an
        evidenced report concerns the project itself — for example, abuse of our name,
        infrastructure, or distribution channels — email
        <Mailto email={EMAIL_ABUSE} /> with specifics. We may revoke
        Pro licenses or restrict access to our services for violations of this policy.
      </p>

      <p class="muted legal__updated">Last updated: 2026-06-24.</p>
    </div>
  </Section>
</Base>

<style>
  .legal {
    max-width: 72ch;
  }
  .legal__updated {
    margin-top: var(--s6);
    padding-top: var(--s5);
    border-top: 1px solid var(--hair);
    font-size: 0.9rem;
  }
</style>

---
import Base from "../layouts/Base.astro";
import Section from "../components/Section.astro";
import PageHeader from "../components/PageHeader.astro";
import Mailto from "../components/Mailto.astro";
import "../styles/content.css";
import { SITE_NAME, GITHUB_URL, EMAIL_SALES } from "../config";
---

<Base title="License" description={`${SITE_NAME} Free is licensed under AGPLv3. The Pro tier adds a commercial EULA. Plain-language summary.`}>
  <Section>
    <PageHeader
      eyebrow="Legal"
      title="License"
      lead="A plain-language summary. The full legal text governs; links below."
    />
    <div class="prose legal">
      <p class="muted legal__note">
        This page is a summary for convenience and is not the license itself. The
        canonical <code>LICENSE</code> in the repository controls.
      </p>

      <h2>Free edition — AGPLv3</h2>
      <p>
        The {SITE_NAME} Free edition is open source under the
        <strong>GNU Affero General Public License v3.0</strong>. In short, you may:
      </p>
      <ul>
        <li>Run the software for any purpose, including commercially.</li>
        <li>Study and modify the source code.</li>
        <li>Redistribute copies and your modifications.</li>
      </ul>
      <p>
        The AGPL's key condition: if you run a modified version as a network service,
        you must offer that service's users the corresponding source. Because {SITE_NAME}
        is local-first, most users never trigger this — but self-hosters offering it to
        others do. See the full
        <a href={`${GITHUB_URL}/blob/main/LICENSE`} target="_blank" rel="noopener noreferrer">AGPLv3 text</a>.
      </p>

      <h2>Pro edition — commercial EULA</h2>
      <p>
        The Pro tier is sold under a commercial end-user license. Summary terms:
      </p>
      <ul>
        <li><strong>One-time purchase</strong> — no subscription, no recurring billing.</li>
        <li><strong>Perpetual for the major version</strong> you bought — yours to keep and use offline.</li>
        <li><strong>Per-user / per-household</strong> license for personal use; the key is for you, not for redistribution.</li>
        <li><strong>Soft upgrade gate</strong> — a newer major may prompt to upgrade; it never disables your installed version.</li>
        <li><strong>Offline validation</strong> — Pro does not phone home to verify your license.</li>
      </ul>

      <h2>Contributions</h2>
      <p>
        Contributions are welcome under the project's Contributor License Agreement, which
        keeps the open-core model sustainable. See <code>CLA.md</code> in the repository.
      </p>

      <h2>Trademarks</h2>
      <p>
        The {SITE_NAME} name and logo are not licensed under the AGPL. You may build and
        redistribute the source, but please don't imply official endorsement.
      </p>

      <p class="legal__contact">
        Licensing questions? Email <Mailto email={EMAIL_SALES} />.
      </p>
    </div>
  </Section>
</Base>

<style>
  .legal {
    max-width: 72ch;
  }
  .legal__note {
    font-size: 0.9rem;
    padding: var(--s3) var(--s4);
    background: var(--sunken);
    border: 1px solid var(--hair);
    border-radius: var(--r-tile);
  }
  .legal__contact {
    margin-top: var(--s6);
    padding-top: var(--s5);
    border-top: 1px solid var(--hair);
  }
</style>

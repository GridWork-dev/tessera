# syntax=docker/dockerfile:1.7
# ===========================================================================
# H100 OFFLOAD image — all 4 tiers, weights pre-baked.
#
# Built to drop spin-up to a few minutes on a Vast.ai verified-DC H100 by
# baking in: vLLM (Tier 2 JoyCaption), onnxruntime-gpu (Tier 0 WD-EVA02 +
# JoyTag), torch + transformers (Tier 1 SigLIP SO400M), nudenet (Tier 3), and
# the model weights themselves so the box never re-pulls from HF mid-rental.
#
# CUDA 12.4 + cuDNN matches the torch cu124 wheels and the onnxruntime-gpu /
# vLLM CUDA 12.x builds current as of mid-2026. Bump the base + pins together
# if you move CUDA versions (parity risk lives in transformers/torch versions —
# pin them to whatever the LOCAL venv runs so SigLIP output matches).
#
# Build (needs ~30-40GB context-free; weights are pulled at build time):
#   docker build -f docker/Dockerfile.h100 -t mp-h100:latest .
# See docker/Dockerfile.h100.md for the full build + push + run note.
# ===========================================================================
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/opt/hf-cache \
    HF_HUB_ENABLE_HF_TRANSFER=1

RUN apt-get update && apt-get install -y --no-install-recommends \
        python3.11 python3.11-venv python3-pip \
        git curl ca-certificates coreutils \
    && rm -rf /var/lib/apt/lists/*

RUN update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# --- Python deps -----------------------------------------------------------
# Pin torch/transformers to the LOCAL venv versions for SigLIP parity. The
# transformers 5.x line is what tier1_embedder was introspected against
# (5.12.1 in the module docstring); keep these in lock-step with the Mac.
RUN pip install --upgrade pip wheel hf_transfer

# torch first (CUDA 12.4 wheels), then the rest.
RUN pip install \
        torch==2.6.0 --index-url https://download.pytorch.org/whl/cu124

RUN pip install \
        transformers==5.12.1 \
        accelerate \
        pillow \
        numpy \
        requests \
        onnxruntime-gpu \
        nudenet \
        vllm

# --- Bake model weights ----------------------------------------------------
# Tier 1 SigLIP SO400M + Tier 2 JoyCaption are pulled into the HF cache so the
# rented box does no network model pulls. ONNX taggers + NudeNet weights are
# COPIED in from the build context (see note: stage them under docker/models/).
RUN python - <<'PY'
from huggingface_hub import snapshot_download
# Tier 1 — SigLIP SO400M (1152-dim image features).
snapshot_download("google/siglip-so400m-patch14-384")
# Tier 2 — JoyCaption Beta One (LLaVA ~8B; vLLM serves it).
snapshot_download("fancyfeast/llama-joycaption-beta-one-hf-llava")
PY

# Tier 0 ONNX weights + label files, and (optionally) NudeNet weights.
# Stage these locally before build:
#   docker/models/wd-eva02/{model.onnx,selected_tags.csv}
#   docker/models/joytag/{model.onnx,top_tags.txt}
# (NudeNet auto-downloads its small ONNX on first NudeDetector() if absent.)
COPY docker/models/ /opt/models/

# --- The runner ------------------------------------------------------------
COPY scripts/remote_pipeline_runner.py /opt/remote_pipeline_runner.py

WORKDIR /work

# vLLM (Tier 2) is started as a separate process by the runbook, e.g.:
#   vllm serve fancyfeast/llama-joycaption-beta-one-hf-llava \
#     --max-model-len 4096 --enable-prefix-caching --gpu-memory-utilization 0.92
# then run all tiers:
#   python /opt/remote_pipeline_runner.py --in-dir /work/images \
#     --out-dir /work/artifacts --models-dir /opt/models --tiers 0,1,2,3
CMD ["python", "/opt/remote_pipeline_runner.py", "--help"]

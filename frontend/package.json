{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome ci .",
    "e2e": "npm run build && playwright test",
    "e2e:app": "npm run build && playwright test --project=app",
    "e2e:site": "playwright test --project=site",
    "e2e:shots": "npm run build && playwright test -g \"shot:\""
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/schibsted-grotesk": "^5.2.8",
    "@fontsource-variable/sora": "^5.2.8",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-virtual": "^3.14.3",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@vanilla-extract/css": "^1.21.0",
    "@vanilla-extract/recipes": "^0.5.7",
    "cmdk": "^1.1.1",
    "justified-layout": "^4.1.0",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@biomejs/biome": "2.5.1",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/vite-plugin": "^5.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "lefthook": "^2.1.9",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vitest": "^3.2.6"
  }
}

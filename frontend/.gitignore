# Font-candidate comparison scratch (mockups, woff2 samples) — box-only
.fonttest/

# TanStack Router — generated route tree. COMMITTED on purpose: the Vite plugin
# regenerates it on dev/build, but `npm run build` runs `tsc -b` BEFORE vite, so
# a clean checkout (CI, fresh clone, backend SPA build) needs the file present or
# tsc fails. Committing it keeps `tsc -b && vite build` working everywhere; the
# plugin keeps it fresh and route changes are committed alongside the routes.

# Playwright e2e artifacts (browsers, reports, traces)
test-results/
playwright-report/
blob-report/
playwright/.cache/
# Visual-audit screenshots (regenerated by `npm run e2e:shots`)
screenshots/

